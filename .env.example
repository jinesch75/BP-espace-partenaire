# Railway provides this automatically when you add a PostgreSQL plugin.
# Locally, copy this file to .env and fill in your own connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Secret used to encrypt the trainee national number at rest.
# Set a long random value in Railway BEFORE loading real data.
# If unset, a dev fallback key is used (fine for the fictional test data only).
ENCRYPTION_KEY="change-me-to-a-long-random-string"
