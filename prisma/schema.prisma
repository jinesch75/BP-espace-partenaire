// Espace partenaire — training course management
// Railway-native: PostgreSQL provided by Railway, no external services.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseType {
  SINGLE
  MULTI
}

enum CourseStatus {
  DRAFT
  OPEN
  COMPLETED
  CANCELLED
}

enum Population {
  POP1
  POP2
}

enum Presence {
  PRESENT
  ABSENT
}

model Partner {
  id              Int      @id @default(autoincrement())
  name            String
  managesTrainees Boolean  @default(false) // true only for ONA
  // general information (managed by the manager)
  description     String?
  contactEmail    String?
  phone           String?
  address         String?
  // login fields
  email           String?  @unique
  passwordHash    String?
  createdAt       DateTime @default(now())

  trainers Trainer[]
  courses  Course[]
}

model Trainer {
  id           Int      @id @default(autoincrement())
  partnerId    Int
  firstName    String
  lastName     String
  email        String?
  passwordHash String?
  createdAt    DateTime @default(now())

  partner  Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@index([partnerId])
}

model Manager {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model Course {
  id                 Int          @id @default(autoincrement())
  partnerId          Int
  title              String
  description        String?
  type               CourseType   @default(SINGLE)
  status             CourseStatus @default(DRAFT)
  recurring          Boolean      @default(false)
  // admin-only fields, set by the manager:
  population         Population?
  visibleInCatalogue Boolean      @default(false)
  createdAt          DateTime     @default(now())

  // Type d'activité (themes), ranked
  topicPrimaryId   Int?
  topicSecondaryId Int?
  topicTertiaryId  Int?
  // Catégories (legal objectives), ranked
  categoryPrimaryId   Int?
  categorySecondaryId Int?
  categoryTertiaryId  Int?

  partner     Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  sessions    Session[]
  badges      Badge[]             @relation("CourseBadges")
  assignments TraineeAssignment[]

  topicPrimary   Topic? @relation("TopicPrimary", fields: [topicPrimaryId], references: [id], onDelete: SetNull)
  topicSecondary Topic? @relation("TopicSecondary", fields: [topicSecondaryId], references: [id], onDelete: SetNull)
  topicTertiary  Topic? @relation("TopicTertiary", fields: [topicTertiaryId], references: [id], onDelete: SetNull)

  categoryPrimary   Category? @relation("CatPrimary", fields: [categoryPrimaryId], references: [id], onDelete: SetNull)
  categorySecondary Category? @relation("CatSecondary", fields: [categorySecondaryId], references: [id], onDelete: SetNull)
  categoryTertiary  Category? @relation("CatTertiary", fields: [categoryTertiaryId], references: [id], onDelete: SetNull)

  @@index([partnerId])
}

model Session {
  id              Int      @id @default(autoincrement())
  courseId        Int
  sequence        Int
  date            DateTime
  startTime       String
  endTime         String
  isOnline        Boolean  @default(false)
  location        String?
  teamsLink       String?
  placesAvailable Int      @default(0)
  trainerId       Int?

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  trainer Trainer? @relation(fields: [trainerId], references: [id], onDelete: SetNull)

  @@index([courseId])
  @@index([trainerId])
}

model Topic {
  id          Int      @id @default(autoincrement())
  name        String
  primaryOf   Course[] @relation("TopicPrimary")
  secondaryOf Course[] @relation("TopicSecondary")
  tertiaryOf  Course[] @relation("TopicTertiary")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  primaryOf   Course[] @relation("CatPrimary")
  secondaryOf Course[] @relation("CatSecondary")
  tertiaryOf  Course[] @relation("CatTertiary")
}

model Badge {
  id      Int      @id @default(autoincrement())
  name    String
  courses Course[] @relation("CourseBadges")
}

model Trainee {
  id             Int      @id @default(autoincrement())
  lastName       String
  firstName      String
  // Sensitive (GDPR). Stored plain in demo with fictional data;
  // encrypt at rest before using real data.
  nationalNumber String
  createdAt      DateTime @default(now())

  assignments TraineeAssignment[]
  dpiStatuses TraineeDpiStatus[]
}

// Manual participation mark for a DPI step that has no concrete activity to
// affect (e.g. a past course no longer in the system). dpiKey is one of
// DAPA1..DAPA5 / BIENV.
model TraineeDpiStatus {
  id        Int      @id @default(autoincrement())
  traineeId Int
  dpiKey    String
  status    Presence
  createdAt DateTime @default(now())

  trainee Trainee @relation(fields: [traineeId], references: [id], onDelete: Cascade)

  @@unique([traineeId, dpiKey])
}

model TraineeAssignment {
  id           Int       @id @default(autoincrement())
  traineeId    Int
  courseId     Int
  assignedDate DateTime
  presence     Presence?
  createdAt    DateTime  @default(now())

  trainee Trainee @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([traineeId, courseId])
  @@index([courseId])
}
